{% extends "admin/_main_nosidebar.html.twig" %}

{% block title %}{{ 'admin.documents.label'|trans }}{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('dashboard') }}">{{ 'dashboard.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin') }}">{{ 'admin.label'|trans }}</a></li>
        <li class="breadcrumb-item">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block table %}
    {% if documents|length == 0 %}
        <div class="card-body">
            <div class="bs-callout bs-callout-info mb-0">
                <h5>{{ 'info.label'|trans }}</h5>

                <p>{{ 'admin.documents.overview.empty'|trans }}</p>
            </div>
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover card-table">
                <colgroup>
                    <col>
                    <col class="column-lg">
                    <col class="column-320">
                    <col class="column-sm">
                </colgroup>

                <thead>
                <tr>
                    <th>{{ 'label.title'|trans }} </th>
                    <th>{{ 'label.category'|trans }}</th>
                    <th>{{ 'label.visibility'|trans }}</th>
                    <th> </th>
                </tr>
                </thead>

                <tbody>
                {% for document in documents %}
                    <tr>
                        <td class="align-middle">
                            {{ document.title }}

                            {% include "_includes/_id.html.twig" with { id: document.id } %}
                        </td>
                        <td class="align-middle">
                            {{ document.category.name }}
                        </td>
                        <td class="align-middle">
                            {% for visibility in document.visibilities %}{{ visibility.userType|enum }}{% if not loop.last %}, {% endif %}{% endfor %}
                        </td>
                        <td class="align-middle">
                            <div class="dropdown">
                                <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>

                                <div class="dropdown-menu dropdown-menu-end">
                                    {% if is_granted('edit', document) %}
                                        <a href="{{ path('admin_edit_document', { uuid: document.uuid }) }}" class="dropdown-item">
                                            <i class="fa fa-edit"></i> {{ 'actions.edit'|trans }}
                                        </a>
                                    {% endif %}
                                    {% if is_granted('remove', document) %}
                                        <a href="{{ path('admin_remove_document', { uuid: document.uuid }) }}" class="dropdown-item text-danger">
                                            <i class="fa fa-trash"></i> {{ 'actions.remove'|trans }}
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

{% endblock %}

{% block count %}
    {{ 'admin.documents.count'|trans({'%count%': documents.totalCount}) }}
{% endblock %}

{% block pagination %}
    {% include '@Common/includes/pagination.html.twig' with {
        currentFilters: {
            grade: gradeFilter.currentGrade?.uuid,
            category: categoryFilter.currentCategory?.uuid,
            user_type: userTypeFilter.currentType?.value,
            q: query
        },
        currentPage: documents.page,
        lastPage: documents.totalPages,
        paginationPath: 'admin_documents',
        showAlwaysFirstAndLast: true
    } %}
{% endblock %}

{% block filter %}
    <form method="get" class="row row-cols-lg-auto g-1 align-items-center">
        <div class="col">
            {% include "_filter/simple/user_type.html.twig" %}
        </div>

        <div class="col">
            {% include "_filter/simple/grade.html.twig" %}
        </div>

        <div class="col">
            <select class="form-select form-select-sm" name="category" data-trigger="submit">
                <option>{{ 'label.select.category'|trans }}</option>
                {% for category in categoryFilter.categories %}
                    <option value="{{ category.uuid }}" {% if category.id == categoryFilter.currentCategory?.id %}selected{% endif %}>{{ category.name }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="col">
            {% include "_filter/simple/query.html.twig" %}
        </div>

        <div class="col">
            <a href="{{ path('admin_documents') }}" class="btn btn-outline-primary btn-sm" title="{{ 'filter.reset'|trans }}">
                <i class="fa-solid fa-filter-circle-xmark"></i>
            </a>
        </div>
    </form>
{% endblock %}

{% block buttons %}
    {% if is_granted('ROLE_DOCUMENTS_ADMIN') %}
        <a href="{{ path('admin_document_categories') }}" class="btn btn-outline-primary btn-sm">
            <i class="fa fa-cogs"></i> {{ 'admin.documents.categories.label'|trans }}
        </a>
    {% endif %}

    {% if is_granted('new-document') %}
        <a href="{{ path('admin_add_document') }}" class="btn btn-primary btn-sm">
            <i class="fa fa-plus"></i> {{ 'admin.documents.add.label'|trans }}
        </a>
    {% endif %}
{% endblock %}
