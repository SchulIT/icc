{% extends "admin/_form.html.twig" %}

{% block title %}{{ 'admin.teachers.edit.label'|trans }}{% endblock %}

{% block post_javascript %}
    <script src="{{ asset('build/picker.js') }}"></script>
    <script src="{{ asset('build/collection.js') }}"></script>
{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('dashboard') }}">{{ 'dashboard.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin') }}">{{ 'admin.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin_teachers') }}">{{ 'admin.teachers.label'|trans }}</a></li>
        <li class="breadcrumb-item">{{ teacher|teacher }}</li>
        <li class="breadcrumb-item">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block inner %}
    {{ form_start(form) }}
    <div class="card">
        <div class="card-header">{{ 'label.general'|trans }}</div>

        <div class="card-body">
            {% for child in form.children %}
                {% if child.vars.name != 'chairs' %}
                    {{ form_row(child) }}
                {% endif %}
            {% endfor %}
        </div>
    </div>

    <div class="card">
        <div class="card-header">{{ 'label.chairs'|trans }}</div>
        <div class="card-body">
            <div class="chairs" data-collection="chairs" data-prototype="{{ form_widget(form.chairs.vars.prototype)|e('html_attr') }}" data-id="{{ form.chairs.vars.id }}">
                {% for chair in form.chairs %}
                    {{ form_widget(chair) }}
                {% endfor %}
            </div>

            {{ form_errors(form.chairs) }}
            {% do form.chairs.setRendered %}
        </div>

        <div class="card-footer">
            <button class="btn btn-outline-primary btn-sm btn-add" type="button" data-collection="chairs">
                <i class="fas fa-plus"></i> {{ 'actions.add'|trans }}
            </button>
        </div>
    </div>

    <div class="buttons">
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="fa fa-save"></i> {{ 'actions.save'|trans }}
        </button>

        <a href="{{ path('admin_teachers') }}" class="btn btn-secondary btn-sm">
            <i class="fa fa-arrow-left"></i> {{ 'actions.back'|trans }}
        </a>
    </div>

    {{ form_end(form) }}
{% endblock %}
