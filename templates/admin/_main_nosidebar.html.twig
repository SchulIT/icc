{% extends "main.html.twig" %}

{% block content %}
    <div class="container-flex px-0">
        <div class="row">
            {% set menu = knp_menu_get('dataMenu') %}
            {% set showVerticalMenu = menu.children|length > 10 %}

            {% if showVerticalMenu %}
                <div class="col-xl-2 d-xl-grid d-md-none d-sm-none d-none sticky-sidebar">
                    {{ knp_menu_render('dataMenu', {'currentClass': 'active', 'template': 'admin/_menu.html.twig' }) }}
                </div>

                <div class="d-xl-none">
                    {{ knp_menu_render('dataMenu', {'currentClass': 'active', 'template': 'admin/_menu_collapsed.html.twig' }) }}
                </div>
            {% else %}
                <div class="d-block">
                    {{ knp_menu_render('dataMenu', {'currentClass': 'active', 'template': 'admin/_menu_horizontal.html.twig' }) }}
                </div>
            {% endif %}

            <div class="{% if showVerticalMenu %}col-xl-10 {% endif %} col-md-12">
                {% block inner %}
                    <div class="card">
                        <div class="card-header">
                            <div class="d-flex flex-wrap mt-n2">
                                <div class="flex-fill mt-2">
                                    {% block filter %}{% endblock %}
                                </div>

                                <div class="ms-auto mt-2">
                                    {% block buttons %}{% endblock %}
                                </div>
                            </div>
                        </div>

                        {% block table %}{% endblock %}

                        <div class="card-footer">
                            <div class="d-flex">
                                <div class="flex-fill align-self-center">
                                    {% block count %}{% endblock %}
                                </div>

                                <div class="ms-auto">
                                    {% block pagination %}{% endblock %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endblock %}
            </div>
        </div>
    </div>
{% endblock %}