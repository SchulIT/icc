{% extends "admin/_form.html.twig" %}

{% block title %}{{ 'admin.appointments.import.label'|trans }}{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('dashboard') }}">{{ 'dashboard.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin') }}">{{ 'admin.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin_appointments') }}">{{ 'admin.appointments.label'|trans }}</a></li>
        <li class="breadcrumb-item">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block inner %}
    {{ form_start(form) }}

    <div class="card">
        <div class="card-header">{{ 'label.general'|trans }}</div>

        <div class="card-body">
            <div class="bs-callout bs-callout-info">
                <p>{{ 'admin.appointments.import.info'|trans }}</p>
                <a href="https://openholidaysapi.org/de" target="_blank" class="btn btn-outline-primary btn-sm">
                    <i class="fas fa-external-link"></i> OpenHolidays API
                </a>
                <a href="{{ path('admin_settings_appointments') }}" class="btn btn-outline-primary btn-sm">
                    <i class="fas fa-cogs"></i> {{ 'import.settings.label'|trans }}
                </a>
            </div>

            {{ form_widget(form) }}
        </div>
    </div>

    <div class="buttons">
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="fa fa-plus"></i> {{ 'actions.add'|trans }}
        </button>

        <a href="{{ path('admin_appointments') }}" class="btn btn-secondary btn-sm">
            <i class="fa fa-arrow-left"></i> {{ 'actions.back'|trans }}
        </a>
    </div>

    {{ form_end(form) }}

{% endblock %}
