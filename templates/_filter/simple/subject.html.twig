<select name="subject" id="subject" class="form-select form-select-sm" data-trigger="submit">
    <option value="" placeholder>{{ 'label.select.subject'|trans }}</option>
    {% for s in subjectFilter.subjects %}
        <option value="{{ s.uuid }}" {% if subjectFilter.currentSubject is not null and  s.id == subjectFilter.currentSubject.id %}selected="selected"{% endif %}>{{ s.name }}</option>
    {% endfor %}
</select>