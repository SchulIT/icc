{% extends "admin/_main_nosidebar.html.twig" %}

{% block title %}{{ 'messages.overview.label'|trans }}{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('dashboard') }}">{{ 'dashboard.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin') }}">{{ 'admin.label'|trans }}</a></li>
        <li class="breadcrumb-item">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block table %}
    {% if messages|length == 0 %}
        <div class="card-body">
            <div class="bs-callout bs-callout-info mb-0">
                <h5>{{ 'info.label'|trans }}</h5>

                <p>{{ 'messages.overview.empty'|trans }}</p>
            </div>
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover card-table">
                <colgroup>
                    <col>
                    <col class="column-320">
                    <col class="column-md">
                    <col class="column-md">
                    <col class="column-320">
                    <col class="column-md">
                    <col class="column-sm">
                </colgroup>

                <thead>
                <tr>
                    <th>{{ 'label.title'|trans }}</th>
                    <th>{{ 'label.visibility'|trans }}</th>
                    <th>{{ 'label.message.start'|trans }}</th>
                    <th>{{ 'message.expires'|trans }}</th>
                    <th>{{ 'label.study_groups'|trans({'%count%': 0}) }}</th>
                    <th></th>
                    <th></th>
                </tr>
                </thead>

                <tbody>
                {% for message in messages %}
                    <tr>
                        <td class="align-middle">
                            {{ message.title }}
                            {% include "_includes/_id.html.twig" with { id: message.id } %}
                        </td>
                        <td class="align-middle">{% include "_includes/visibilities.html.twig" with { visibilities: message.visibilities } only %}</td>
                        <td class="align-middle">
                            {{ message.startDate|format_date }}
                        </td>
                        <td class="align-middle">
                            {{ message.expireDate|format_date }}
                        </td>
                        <td class="align-middle">{% include "_includes/study_groups.html.twig" with { studyGroups: message.studyGroups, id: message.uuid } only %}</td>
                        <td class="align-middle">
                            {% if message.mustConfirm %}
                                <i class="fas fa-tasks" title="{{ 'message.confirmations.label'|trans }}"></i>
                            {% endif %}
                            {% if message.isPollEnabled %}
                                <i class="fas fa-poll" title="{{ 'messages.poll.label'|trans }}"></i>
                            {% endif %}
                            {% if message.downloadsEnabled %}
                                <i class="fa fa-download" title="{{ 'messages.downloads.label'|trans }}"></i>
                            {% endif %}
                            {% if message.uploadsEnabled %}
                                <i class="fa fa-upload" title="{{ 'messages.uploads.label'|trans }}"></i>
                            {% endif %}
                        </td>
                        <td class="align-middle">
                            <div class="dropdown">
                                <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>

                                <div class="dropdown-menu dropdown-menu-end">
                                    {% if is_granted('view', message) %}
                                        <a href="{{ path('show_message', { uuid: message.uuid }) }}" class="dropdown-item">
                                            <i class="fas fa-envelope-open-text"></i> {{ 'actions.view'|trans }}
                                        </a>
                                    {% endif %}

                                    {% if is_granted('edit', message) %}
                                        <a href="{{ path('edit_message', { uuid: message.uuid }) }}" class="dropdown-item">
                                            <i class="fa fa-edit"></i> {{ 'actions.edit'|trans }}
                                        </a>

                                        {% if message.mustConfirm %}
                                            <a href="{{ path('message_confirmations', { uuid: message.uuid }) }}" class="dropdown-item">
                                                <i class="fas fa-tasks"></i> {{ 'message.confirmations.label'|trans }}
                                            </a>
                                        {% endif %}

                                        {% if message.isPollEnabled %}
                                            <a href="{{ path('poll_result', { uuid: message.uuid }) }}" class="dropdown-item">
                                                <i class="fas fa-poll"></i> {{ 'messages.poll.result.label'|trans }}
                                            </a>
                                        {% endif %}

                                        {% if message.downloadsEnabled %}
                                            <a href="{{ path('message_downloads_admin', { uuid: message.uuid }) }}" class="dropdown-item">
                                                <i class="fa fa-download"></i> {{ 'messages.downloads.label'|trans }}
                                            </a>
                                        {% endif %}
                                        {% if message.uploadsEnabled %}
                                            <a href="{{ path('message_uploads_admin', { uuid: message.uuid }) }}" class="dropdown-item">
                                                <i class="fa fa-upload"></i> {{ 'messages.uploads.label'|trans }}
                                            </a>
                                        {% endif %}
                                    {% endif %}
                                    {% if is_granted('remove', message) %}
                                        <a href="{{ path('remove_message', { uuid: message.uuid }) }}" class="dropdown-item text-danger">
                                            <i class="fa fa-trash"></i> {{ 'actions.remove'|trans }}
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}

{% block filter %}
    <form method="get" class="row row-cols-lg-auto g-1 align-items-center">
        <div class="col">
            {% include "_filter/simple/user_type.html.twig" %}
        </div>

        <div class="col">
            {% include "_filter/simple/query.html.twig" %}
        </div>

        <div class="col">
            <div class="btn-group btn-group-sm" role="group">
                <input type="radio" class="btn-check" name="all" value="false" id="allFalse" autocomplete="off" data-trigger="submit" {% if not all %}checked{% endif %}>
                <label class="btn btn-outline-primary" for="allFalse">{{ 'admin.messages.all.false'|trans }}</label>

                <input type="radio" class="btn-check" name="all" value="true" id="allTrue" autocomplete="off" data-trigger="submit" {% if all %}checked{% endif %}>
                <label class="btn btn-outline-primary" for="allTrue">{{ 'admin.messages.all.true'|trans }}</label>
            </div>
        </div>

        <div class="col">
            <a href="{{ path('admin_messages') }}" class="btn btn-outline-primary btn-sm" title="{{ 'filter.reset'|trans }}">
                <i class="fa-solid fa-filter-circle-xmark"></i>
            </a>
        </div>
    </form>
{% endblock %}

{% block buttons %}
    {% if is_granted('remove-messages-bulk') %}
        <a href="{{ path('remove_expired_messages') }}" class="btn btn-outline-danger btn-sm">
            <i class="fas fa-trash"></i> {{ 'admin.messages.bulk_remove.label'|trans }}
        </a>
    {% endif %}

    <a href="{{ path('add_message') }}" class="btn btn-primary btn-sm">
        <i class="fa fa-plus"></i> {{ 'messages.add.label'|trans }}
    </a>
{% endblock %}

{% block count %}
    {{ 'admin.messages.count'|trans({'%count%': messages.totalCount}) }}
{% endblock %}

{% block pagination %}
    {% include '@Common/includes/pagination.html.twig' with {
        currentFilters: {
            user_type: userTypeFilter.currentType?.value,
            q: query,
            all: all
        },
        currentPage: messages.page,
        lastPage: messages.totalPages,
        paginationPath: 'admin_messages',
        showAlwaysFirstAndLast: true
    } %}
{% endblock %}