{% extends "admin/_main_nosidebar.html.twig" %}

{% block title %}{{ 'admin.teachers.label'|trans }}{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('dashboard') }}">{{ 'dashboard.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin') }}">{{ 'admin.label'|trans }}</a></li>
        <li class="breadcrumb-item">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block filter %}
    <form method="get" class="row row-cols-lg-auto g-1 align-items-center">
        <div class="col">
            {% include "_filter/simple/subject.html.twig" %}
        </div>

        <div class="col">
            <select name="tag" class="form-select form-select-sm" data-trigger="submit">
                <option>{{ 'label.select.tag'|trans }}</option>
                {% for tag in teacherTagFilter.tags %}
                    <option value="{{ tag.uuid }}" {% if tag.id == teacherTagFilter.currentTag?.id %}selected{% endif %}>
                        {{ tag.name }}
                    </option>
                {% endfor %}
            </select>
        </div>

        <div class="col">
            <a href="{{ path('admin_teachers') }}" class="btn btn-outline-primary btn-sm" title="{{ 'filter.reset'|trans }}">
                <i class="fa-solid fa-filter-circle-xmark"></i>
            </a>
        </div>
    </form>
{% endblock %}

{% block buttons %}
    <a href="{{ path('admin_teacher_tags') }}" class="btn btn-outline-primary btn-sm">
        <i class="fa fa-cogs"></i> {{ 'admin.teachers.tags.label'|trans }}
    </a>

    <a href="{{ path('add_teacher') }}" class="btn btn-primary btn-sm">
        <i class="fas fa-plus"></i> {{ 'admin.teachers.add.label'|trans }}
    </a>
{% endblock %}

{% block table %}
    {% if teachers|length == 0 %}
        <div class="card-body">
            <div class="bs-callout bs-callout-info">
                <h5>{{ 'info.label'|trans }}</h5>

                <p>{{ 'admin.teachers.overview.empty'|trans }}</p>
            </div>
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover card-table">
                <colgroup>
                    <col class="column-md">
                    <col>
                    <col>
                    <col class="column-md">
                    <col class="column-lg">
                    <col class="column-lg">
                    <col class="column-sm">
                </colgroup>

                <thead>
                <tr>
                    <th>{{ 'label.acronym'|trans }}</th>
                    <th>{{ 'label.firstname'|trans }}</th>
                    <th>{{ 'label.lastname'|trans }}</th>
                    <th>{{ 'label.title'|trans }}</th>
                    <th>{{ 'label.subjects'|trans }}</th>
                    <th>{{ 'label.tags'|trans }}</th>
                    <th></th>
                </tr>
                </thead>

                <tbody>
                {% for teacher in teachers %}
                    <tr>
                        <td class="align-middle">
                            {{ teacher.acronym }}

                            {% include "_includes/_id.html.twig" with { id: teacher.id } %}
                        </td>
                        <td class="align-middle">{{ teacher.firstname}}</td>
                        <td class="align-middle">{{ teacher.lastname }}</td>
                        <td class="align-middle">{{ teacher.title }}</td>
                        <td class="align-middle">
                            {% for subject in teacher.subjects %}{{ subject.name }}{% if not loop.last %}, {% endif %}{% endfor %}
                        </td>
                        <td class="align-middle">
                            {% for tag in teacher.tags %}{{ tag.name }}{% if not loop.last %}, {% endif %}{% endfor %}
                        </td>
                        <td class="align-middle">
                            <div class="dropdown">
                                <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>

                                <div class="dropdown-menu dropdown-menu-end">
                                    <a href="{{ path('edit_teacher', { uuid: teacher.uuid }) }}" class="dropdown-item">
                                        <i class="fa fa-edit"></i> {{ 'actions.edit'|trans }}
                                    </a>

                                    <a href="{{ path('remove_teacher', { uuid: teacher.uuid }) }}" class="dropdown-item text-danger">
                                        <i class="fa fa-trash"></i> {{ 'actions.remove'|trans }}
                                    </a>
                                </div>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}

{% block count %}
    {{ 'admin.teachers.count'|trans({'%count%': teachers.totalCount}) }}
{% endblock %}

{% block pagination %}
    {% include '@Common/includes/pagination.html.twig' with {
        currentFilters: {
            subject: subjectFilter.currentSubject?.uuid,
            tag: teacherTagFilter.currentTag?.uuid
        },
        currentPage: teachers.page,
        lastPage: teachers.totalPages,
        paginationPath: 'admin_teachers',
        showAlwaysFirstAndLast: true
    } %}
{% endblock %}