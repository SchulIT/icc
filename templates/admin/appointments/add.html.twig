{% extends "admin/_form.html.twig" %}

{% block post_javascript %}
    <script src="{{ asset('build/editor.js') }}"></script>
    <script src="{{ asset('build/collection.js') }}"></script>
{% endblock %}

{% block title %}{{ 'admin.appointments.add.label'|trans }}{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('dashboard') }}">{{ 'dashboard.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin') }}">{{ 'admin.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin_appointments') }}">{{ 'admin.appointments.label'|trans }}</a></li>
        <li class="breadcrumb-item">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block inner %}
    {% if not is_granted('ROLE_APPOINTMENTS_ADMIN') %}
        <div class="bs-callout bs-callout-warning">
            <h5>{{ 'important'|trans }}</h5>

            <p>{{ 'admin.appointments.add.confirmation_info'|trans }}</p>
        </div>

        <div class="bs-callout bs-callout-danger">
            <h5>{{ 'caution'|trans }}</h5>

            <p>{{ 'admin.appointments.add.workflow_info'|trans }}</p>
        </div>
    {% endif %}

    {{ form_start(form) }}

    {{ form_row(form.group_general) }}
    {{ form_row(form.group_people) }}

    {% if form.group_recurring is defined %}
    <div class="card">
        <div class="card-header">{{ 'admin.appointments.recurring.label'|trans }}</div>

        <div class="card-body">
            {{ form_row(form.group_recurring.isRecurring) }}

            <div class="mb-3 row">
                {{ form_label(form.group_recurring.recurringGradeNames) }}

                <div class="col-md-10">
                    <div class="grade_names" data-collection="grades" data-prototype="{{ form_widget(form.group_recurring.recurringGradeNames.vars.prototype)|e('html_attr') }}" data-id="{{ form.group_recurring.recurringGradeNames.vars.id }}">
                        {% for gradeName in form.group_recurring.recurringGradeNames %}
                            {{ form_widget(gradeName) }}
                        {% endfor %}
                    </div>

                    <button class="btn btn-outline-primary btn-sm btn-add" type="button" data-collection="grades">
                        <i class="fas fa-plus"></i> {{ 'actions.add'|trans }}
                    </button>

                    {{ form_errors(form.group_recurring.recurringGradeNames) }}
                    {{ form_help(form.group_recurring.recurringGradeNames) }}

                    {% do form.group_recurring.recurringGradeNames.setRendered %}
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    <div class="buttons">
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="fa fa-plus"></i> {{ 'actions.add'|trans }}
        </button>

        <a href="{{ path('admin_appointments') }}" class="btn btn-secondary btn-sm">
            <i class="fa fa-arrow-left"></i> {{ 'actions.back'|trans }}
        </a>
    </div>

    {{ form_end(form) }}

{% endblock %}
