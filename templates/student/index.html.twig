{% extends 'main.html.twig' %}

{% block title %}{{ 'students.label'|trans }}{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('dashboard') }}">{{ 'dashboard.label'|trans }}</a></li>
        <li class="breadcrumb-item">{{ 'students.label'|trans }}</li>
    </ol>
{% endblock %}

{% block content %}
<div class="container-fluid px-0">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex">
                        <div class="flex-fill">
                            <form method="get" class="row row-cols-lg-auto g-1 align-items-center">
                                <div class="col">
                                    {% include "_filter/simple/section.html.twig" %}
                                </div>
                                <div class="col">
                                    {% include "_filter/simple/grade.html.twig" %}
                                </div>
                                <div class="col">
                                    {% include "_filter/simple/query.html.twig" with { placeholder: 'students.query'|trans} %}
                                </div>

                                <div class="col">
                                    <a href="{{ path('students') }}" class="btn btn-outline-primary btn-sm">
                                        <i class="fas fa-times-circle"></i>
                                    </a>
                                </div>
                            </form>
                        </div>

                        <div class="ms-auto">
                            {% if is_granted('new-student-info') %}
                                <a href="{{ path('student_information_index') }}" class="btn btn-outline-primary btn-sm" title="{{ 'students.extra.help'|trans }}">
                                    <i class="fas fa-circle-info"></i> {{ 'students.extra.label'|trans }}
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="list-group list-group-flush">
                    {% for student in students %}
                        <a href="{{ path('show_student', { uuid: student.uuid, section: sectionFilter.currentSection.uuid }) }}" class="list-group-item list-group-item-action">
                            <i class="fas fa-user"></i> {{ student.lastname }}, {{ student.firstname }}

                            {% set grade = student.grade(sectionFilter.currentSection) %}

                            {% if grade is not null %}
                                <span class="badge text-bg-primary">{{ grade.name }}</span>
                            {% endif %}
                        </a>
                    {% endfor %}
                </div>

                <div class="card-footer">
                    <div class="d-flex">
                        <div class="flex-fill align-self-center">
                            {{ 'students.count'|trans({'%count%': students.totalCount}) }}
                        </div>

                        <div class="ms-start">
                            {% include '@Common/includes/pagination.html.twig' with {
                                currentFilters: {
                                    grade: gradeFilter.currentGrade?.uuid,
                                    section: sectionFilter.currentSection?.uuid,
                                    q: query
                                },
                                currentPage: students.page,
                                paginationPath: 'students',
                                lastPage: students.totalPages,
                                showAlwaysFirstAndLast: true
                            } only %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}