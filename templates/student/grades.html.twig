{% extends 'main.html.twig' %}

{% block title %}{{ student|student }}{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('dashboard') }}">{{ 'dashboard.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('students') }}">{{ 'students.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('show_student', { uuid: student.uuid }) }}">{{ block('title') }}</a></li>
        <li class="breadcrumb-item active">{{ 'students.grades.label'|trans }}</li>
    </ol>
{% endblock %}

{% block post_javascript %}
    <script src="{{ asset('build/gradebook.js') }}"></script>
{% endblock %}

{% block content %}

    <div id="key" class="hide" data-ttl="{{ ttl }}">{{ key }}</div>

    <div class="card">
        <div class="card-header">
            <div class="d-flex">
                <div class="flex-fill">
                    {% include "student/_navigation.html.twig" with { active: 'grades' } %}
                </div>

                <div class="ms-auto align-self-center">
                    <form method="get">
                        {% include "_filter/simple/section.html.twig" %}
                    </form>
                </div>
            </div>
        </div>

        <div class="card-header input-group input-group-sm">
            <input type="password" id="passphrase" class="form-control" autocomplete="off" data-enter="#password_btn" placeholder="{{ 'label.password'|trans }}" />
            <button type="button" id="password_btn" data-passphrase="#passphrase" data-key="#key" class="btn btn-outline-primary">
                <i class="fas fa-check"></i>
            </button>
        </div>

        <table class="table table-striped table-bordered table-hover card-table" id="grades">
            <colgroup>
                <col>
                {% for category in overview.categories %}
                    <col class="column-sm">
                {% endfor %}
            </colgroup>

            <thead>
            <tr>
                <th>{{ 'label.tuition'|trans }}</th>
                {% for category in overview.categories %}
                    <th class="rotate-90">
                        <div>
                            {{ category.category.displayName }}
                        </div>
                    </th>
                {% endfor %}
            </tr>
            </thead>

            <tbody>
            {% set rowCount = overview.rows|length %}
            {% for row in overview.rows %}
                {% set rowIdx = loop.index0 %}
                <tr>
                    <td class="align-middle" data-xlsx="raw">
                        {{ row.tuitionOrStudent.name }}
                    </td>
                    {% for category in overview.categories %}
                        {% set colorMap = category.category.catalog|gradeCatalogColorMap %}
                        <td class="align-middle text-center" data-xlsx="encrypted">
                            {% set grade = row.grade(row.tuitionOrStudent, category.category) %}
                            {% set name = 'grades[' ~ row.tuitionOrStudent.uuid ~ '][' ~ category.category.uuid ~ ']' ~ '[' ~ category.tuition.uuid ~ ']' %}

                            {% set id = name|replace({'[': '_', ']': '_'}) %}
                            <input type="hidden" data-encrypted="{{ grade != null ? grade.encryptedGrade|e('html_attr') : '' }}" value="{{ grade != null ? grade.encryptedGrade|e('html_attr') : '' }}" data-select="#{{ id }}" name="{{ name }}" data-colormap="{{ colorMap|json_encode|e('html_attr') }}">

                            <span id="{{ id }}"><i class="fas fa-lock"></i></span>
                        </td>
                    {% endfor %}
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="card-footer">
            <a href="{{ path('gradebook', { student: student.uuid, section: sectionFilter.currentSection.uuid }) }}" class="btn btn-primary btn-sm">
                <i class="fas fa-external-link-alt"></i> {{ 'book.grades.label'|trans }}
            </a>
        </div>

    </div>
{% endblock %}