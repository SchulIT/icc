{% extends "main.html.twig" %}

{% block title %}{{ 'book.export.schild_zeugnisbemerkungen.label'|trans }}{% endblock %}

{% block breadcrumb %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('dashboard') }}">{{ 'dashboard.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('book') }}">{{ 'book.label'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('book_export') }}">{{ 'book.export.label'|trans }}</a> </li>
        <li class="breadcrumb-item">{{ block('title') }}</li>
    </ol>
{% endblock %}

{% block content %}
    <div class="container-fluid px-0">
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-body">
                        {{ form_start(form) }}

                        {{ form_widget(form) }}

                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="fas fa-download"></i> {{ 'book.export.schild_zeugnisbemerkungen.button'|trans }}
                        </button>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

